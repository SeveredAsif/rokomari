# Database Configuration
DATABASE_URL=postgresql+psycopg2://admin:password@postgres:5432/rokomari

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-here

# Service-to-Service Authentication
SERVICE_TO_SERVICE_TOKEN=your-internal-service-token-here

# Redis Configuration (optional, for caching)
REDIS_URL=redis://redis:6379/0

# Postgres Configuration (for docker-compose)
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=rokomari

# Access Token Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Service URLs
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8001
